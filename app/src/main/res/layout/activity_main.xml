<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="30dp"
    android:background="@color/background_dark"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_main"
        android:textColor="@color/primary_blue"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="20dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/subtitle_main"
        android:textColor="@color/text_gray"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="30dp" />

    <!-- Original File Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="25dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOriginalFile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/btn_choose_original"
            android:textStyle="bold"
            app:backgroundTint="@color/btn_original_bg"
            app:cornerRadius="15dp" />

        <TextView
            android:id="@+id/tvOriginalFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_file_selected"
            android:textColor="@color/text_gray"
            android:gravity="center"
            android:layout_marginTop="5dp" />
    </LinearLayout>

    <!-- Patch File Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="30dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPatchFile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/btn_choose_patch"
            android:textStyle="bold"
            app:backgroundTint="@color/btn_patch_bg"
            app:cornerRadius="15dp" />

        <TextView
            android:id="@+id/tvPatchFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_file_selected"
            android:textColor="@color/text_gray"
            android:gravity="center"
            android:layout_marginTop="5dp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:max="100"
        android:progress="0"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/status_ready"
        android:textColor="@color/status_success"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartPatch"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="@string/btn_start_patch"
        android:textSize="20sp"
        android:textStyle="bold"
        app:backgroundTint="@color/btn_start_disabled"
        android:enabled="false"
        app:cornerRadius="15dp"
        android:layout_marginBottom="20dp"/>

</LinearLayout>
